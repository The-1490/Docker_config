{
  "task-runners": [
    {
      "runner-type": "javascript",
      "env-overrides": {
        "NODE_FUNCTION_ALLOW_EXTERNAL": "lodash,moment,axios,date-fns"
      }
    },
    {
      "runner-type": "python",
      "env-overrides": {
        "PYTHONPATH": "/opt/runners/task-runner-python",
        "N8N_RUNNERS_EXTERNAL_ALLOW": "pandas,numpy,requests,bs4,lxml,openpyxl"
      }
    }
  ]
}
